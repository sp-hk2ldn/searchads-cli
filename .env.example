# Apple Ads credentials
# Copy to .env for local use, then load with:
#   set -a; source .env; set +a

# Option 1: single JSON credential blob
# SEARCHADS_CREDENTIALS_JSON='{"clientId":"...","teamId":"...","keyId":"...","privateKey":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----","orgId":"..."}'

# Option 2: split env vars
SEARCHADS_CLIENT_ID=
SEARCHADS_TEAM_ID=
SEARCHADS_KEY_ID=
SEARCHADS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional
SEARCHADS_ORG_ID=
SEARCHADS_POPULARITY_ADAM_ID=
SEARCHADS_POPULARITY_ADGROUP_ID=
SEARCHADS_POPULARITY_WEB_COOKIE=
SEARCHADS_POPULARITY_XSRF_TOKEN=
